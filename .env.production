# Production Environment Variables
# Скопируйте этот файл в .env.production и заполните реальными значениями

# ====================
# Environment
# ====================
ENV=production
LOG_LEVEL=info

# ====================
# Database (PostgreSQL)
# ====================
POSTGRES_DB=child_bot
POSTGRES_USER=child_bot
POSTGRES_PASSWORD=0xVQhgOz8E7EPVQZu0E5x7ZzixdwoX5d

# ====================
# Cache (Redis)
# ====================
REDIS_PASSWORD=G8uESoxbJxZdiNnTJbwlSYtAu1xPGn37

# ====================
# Backend API
# ====================
PORT=8080

# LLM Service
DEFAULT_LLM=gpt
LLM_SERVER_URL=http://138.124.55.145:8000

# CORS (укажите реальные домены)
ALLOWED_ORIGINS=http://77.222.60.149,https://77.222.60.149,https://vk.com

# App URL (base URL для реферальных ссылок)
APP_URL=https://77.222.60.149

# ====================
# VK Mini App
# ====================
VK_APP_ID=54517931
VK_APP_SECRET=BNE8tONS2h0rRjHyx9wk

# ====================
# Email Service
# ====================
# Рекомендуется Mailtrap (1000 писем/месяц бесплатно): https://mailtrap.io
# Поддерживаемые провайдеры: mailtrap (default), sendgrid, ses, mailgun
EMAIL_PROVIDER=mailtrap
EMAIL_API_KEY=your_mailtrap_api_key_here
EMAIL_FROM=noreply@swtest.ru

# ====================
# Frontend (Vite build args)
# ====================
VITE_API_BASE_URL=/api/v1
VITE_APP_VERSION=1.0.0
VITE_ANALYTICS_ENABLED=true
VITE_VK_APP_ID=54517931
VITE_MAX_APP_ID=your_max_app_id
VITE_TELEGRAM_BOT_USERNAME=your_bot_username

GITHUB_REPOSITORY_OWNER=knopka87
