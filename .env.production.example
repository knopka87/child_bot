# Docker Compose Environment Variables (Production)
# Скопируйте этот файл в .env для production деплоя

# ====================
# Environment
# ====================
ENV=production

# ====================
# Database (PostgreSQL)
# ====================
POSTGRES_DB=child_bot
POSTGRES_USER=child_bot
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION_STRONG_PASSWORD
POSTGRES_PORT=5432
DATABASE_URL=postgres://child_bot:CHANGE_ME@postgres:5432/child_bot?sslmode=disable

# ====================
# Cache (Redis)
# ====================
REDIS_PASSWORD=CHANGE_ME_IN_PRODUCTION_STRONG_PASSWORD
REDIS_PORT=6379
REDIS_URL=redis://:CHANGE_ME@redis:6379/0

# ====================
# Backend API
# ====================
PORT=8080
BACKEND_PORT=8080
LOG_LEVEL=info

# LLM Client
DEFAULT_LLM=gpt
LLM_SERVER_URL=http://your-llm-server:8000

# CORS (укажите реальные домены)
ALLOWED_ORIGINS=https://your-domain.com,https://vk.com

# App URL (base URL для реферальных ссылок)
APP_URL=https://your-domain.com

# ====================
# Frontend
# ====================
FRONTEND_PORT=80
VITE_API_BASE_URL=/api/v1
VITE_APP_VERSION=1.0.0
VITE_ANALYTICS_ENABLED=true

# VK Mini App (production IDs)
VITE_VK_APP_ID=your_production_vk_app_id
VITE_MAX_APP_ID=your_production_max_app_id
VITE_TELEGRAM_BOT_USERNAME=your_production_bot_username

# Legal URLs
VITE_PRIVACY_POLICY_URL=https://your-domain.com/legal/privacy
VITE_TERMS_OF_SERVICE_URL=https://your-domain.com/legal/terms

# ====================
# External Services
# ====================
# VK API
VK_APP_ID=your_vk_app_id
VK_APP_SECRET=your_vk_app_secret_here
VK_CONFIRMATION_CODE=your_vk_confirmation_code

# Email Service (для верификации родителей)
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=your_email_api_key_here
EMAIL_FROM=support@your-domain.com

# Webhooks
WEBHOOK_URL=

# Sentry (error tracking)
SENTRY_DSN=

# Analytics
AMPLITUDE_API_KEY=
