# Docker Compose Environment Variables (Development)
# Скопируйте этот файл в .env и заполните значения

# ====================
# Database (PostgreSQL)
# ====================
POSTGRES_DB=child_bot
POSTGRES_USER=child_bot
POSTGRES_PASSWORD=dev_secret
POSTGRES_PORT=5432
DATABASE_URL=postgres://child_bot:dev_secret@localhost:5432/child_bot?sslmode=disable

# ====================
# Cache (Redis)
# ====================
REDIS_PASSWORD=dev_redis_secret
REDIS_PORT=6379
REDIS_URL=redis://:dev_redis_secret@localhost:6379/0

# ====================
# Backend API
# ====================
PORT=8080
BACKEND_PORT=8080
ENV=development
LOG_LEVEL=debug

# LLM Client
DEFAULT_LLM=gpt
LLM_SERVER_URL=http://138.124.55.145:8000

# CORS (для development разрешаем localhost)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# App URL (base URL для реферальных ссылок)
APP_URL=http://localhost:5173

# ====================
# Frontend
# ====================
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_APP_VERSION=dev
VITE_ANALYTICS_ENABLED=true

# VK Mini App
VITE_VK_APP_ID=your_vk_app_id_here
VITE_MAX_APP_ID=your_max_app_id_here
VITE_TELEGRAM_BOT_USERNAME=your_bot_username_here

# Legal URLs (для dev используем локальные)
VITE_PRIVACY_POLICY_URL=http://localhost:5173/legal/privacy
VITE_TERMS_OF_SERVICE_URL=http://localhost:5173/legal/terms

# ====================
# External Services
# ====================
# VK API (if needed)
VK_APP_ID=
VK_SECRET_KEY=

# Sentry (error tracking)
SENTRY_DSN=

# Analytics
AMPLITUDE_API_KEY=
